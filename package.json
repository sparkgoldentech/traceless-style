{
  "name": "spark-css",
  "version": "3.0.0",
  "description": "Zero-runtime atomic CSS. Build-time compilation. Safe AST parser. Webpack + Turbopack. Server Components. No Babel.",
  "author": "Spark Golden Tech <contact@sparkgoldentech.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sparkgoldentech/spark-css"
  },
  "keywords": [
    "css-in-js",
    "atomic-css",
    "zero-runtime",
    "build-time",
    "hashed-classes",
    "nextjs",
    "server-components",
    "typescript",
    "design-tokens",
    "webpack",
    "turbopack",
    "safe"
  ],
  "main": "./dist/runtime/index.js",
  "module": "./dist/runtime/index.mjs",
  "types": "./dist/runtime/index.d.ts",
  "bin": {
    "spark-css": "./dist/cli/extract.js"
  },
  "exports": {
    ".": {
      "types": "./dist/runtime/index.d.ts",
      "import": "./dist/runtime/index.mjs",
      "require": "./dist/runtime/index.js"
    },
    "./nextjs": {
      "types": "./dist/nextjs.d.ts",
      "import": "./dist/nextjs.mjs",
      "require": "./dist/nextjs.js"
    },
    "./webpack": {
      "types": "./dist/plugins/webpack.d.ts",
      "import": "./dist/plugins/webpack.mjs",
      "require": "./dist/plugins/webpack.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "node test/test.mjs",
    "prepublishOnly": "npm run build && npm test"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "next": ">=14.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    },
    "webpack": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/webpack": "^5.0.0",
    "next": ">=15.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "webpack": "^5.0.0"
  }
}