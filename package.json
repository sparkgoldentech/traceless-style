{
  "name": "traceless-style",
  "version": "3.0.0",
  "description": "Zero-runtime atomic CSS. Build-time compilation. Safe AST parser. Webpack + Turbopack + Vite + Rollup + esbuild. Server Components. No Babel.",
  "author": "Spark Golden Tech <contact@sparkgoldentech.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sparkgoldentech/traceless-style"
  },
  "keywords": [
    "css-in-js",
    "atomic-css",
    "zero-runtime",
    "build-time",
    "hashed-classes",
    "nextjs",
    "server-components",
    "typescript",
    "design-tokens",
    "webpack",
    "turbopack",
    "safe"
  ],
  "main": "./dist/runtime/index.js",
  "module": "./dist/runtime/index.mjs",
  "types": "./dist/runtime/index.d.ts",
  "bin": {
    "traceless-style": "./dist/cli/extract.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/runtime/index.d.ts",
      "import": "./dist/runtime/index.mjs",
      "require": "./dist/runtime/index.js",
      "default": "./dist/runtime/index.js"
    },
    "./nextjs": {
      "types": "./dist/nextjs.d.ts",
      "import": "./dist/nextjs.mjs",
      "require": "./dist/nextjs.js",
      "default": "./dist/nextjs.js"
    },
    "./webpack": {
      "types": "./dist/plugins/webpack.d.ts",
      "import": "./dist/plugins/webpack.mjs",
      "require": "./dist/plugins/webpack.js",
      "default": "./dist/plugins/webpack.js"
    },
    "./vite": {
      "types": "./dist/plugins/vite.d.ts",
      "import": "./dist/plugins/vite.mjs",
      "require": "./dist/plugins/vite.js",
      "default": "./dist/plugins/vite.js"
    },
    "./rollup": {
      "types": "./dist/plugins/rollup.d.ts",
      "import": "./dist/plugins/rollup.mjs",
      "require": "./dist/plugins/rollup.js",
      "default": "./dist/plugins/rollup.js"
    },
    "./esbuild": {
      "types": "./dist/plugins/esbuild.d.ts",
      "import": "./dist/plugins/esbuild.mjs",
      "require": "./dist/plugins/esbuild.js",
      "default": "./dist/plugins/esbuild.js"
    },
    "./dark": {
      "types": "./dist/dark.d.ts",
      "import": "./dist/dark.mjs",
      "require": "./dist/dark.js",
      "default": "./dist/dark.js"
    },
    "./rtl": {
      "types": "./dist/rtl.d.ts",
      "import": "./dist/rtl.mjs",
      "require": "./dist/rtl.js",
      "default": "./dist/rtl.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup && node scripts/post-build.mjs",
    "dev": "tsup --watch",
    "test": "vitest run",
    "bench": "npm run build && node bench/run-all.mjs",
    "prepublishOnly": "npm run build && npm test"
  },
  "peerDependencies": {
    "next": ">=14.0.0",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    },
    "webpack": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "@swc/core": "^1.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/webpack": "^5.0.0",
    "next": ">=15.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.5",
    "webpack": "^5.0.0"
  }
}
